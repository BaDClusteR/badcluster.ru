<?php
/** @noinspection PhpFullyQualifiedNameUsageInspection */
/** @var \BC\Widget\Common\Block\Paragraph $this */
$content = $this->getContent();
$align = $this->getAlignment();
?><?php if ($content) : ?>
    <p<?php if ($align) : ?> class="align-<?=$align?>"<?php endif; ?>><?=$content?></p>
<?php else : ?>
    <p class="empty" aria-hidden="true">&nbsp;</p>
<?php endif; ?>
